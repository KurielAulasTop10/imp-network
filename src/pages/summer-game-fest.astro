---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { cdn } from "@/utils/cdn";
import EventCountdown from "@/components/EventCountdown";
import EventCalendar from "@/components/ui/event-calendar";
---

<BaseLayout title="Evento Summer Game Fest 2026">
    <div class="text-white">
        <div class="mx-auto px-4 py-16 max-w-7xl">
            <div class="flex flex-col items-center justify-center lg:flex-row gap-12 mb-20">
                <div class="w-full max-w-lg">
                    <img src={cdn("https://cdn.prod.website-files.com/65f20ae26ba45240543579bc/67e9dcd31ffdef7916a3c857_sgf_modal_logo.webp", 0, 0)} alt="GOTY Trophy" class="w-full h-auto transform hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="flex flex-col items-center text-center lg:text-left lg:items-start">
                    <div class="mb-2">
                        <span class="bg-linear-to-r from-red-600 to-red-500 text-white px-4 py-2 rounded-full text-sm font-bold mb-2">EVENTO ANUAL</span>
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-black mb-6 tracking-tight bg-linear-to-r from-white to-gray-300 bg-clip-text text-transparent">Summer Game Fest {new Date().getFullYear()}</h1>
                    <p class="text-xl lg:text-2xl text-gray-300 max-w-2xl leading-relaxed mb-8">O maior evento de anúncios de jogos está de volta! Fique por dentro das novidades anuais que vários indies e empresas estão ansiosas para revelar.</p>
                    <a href="https://www.summergamefest.com" target="_blank" rel="noopener noreferrer" class="group bg-linear-to-r from-red-600 to-red-500 hover:from-red-500 hover:to-red-400 text-white px-8 py-4 rounded-2xl text-lg font-bold transition-all duration-300 transform hover:scale-105 shadow-2xl hover:shadow-3xl inline-flex items-center gap-3">
                        Veja Mais Detalhes
                    </a>
                </div>
            </div>

            <div class="flex flex-col items-center gap-12 mb-20 text-center">
                    <EventCountdown client:load />
                    <p class="text-xl text-gray-400 max-w-3xl">Não perca o maior evento da indústria de games com anúncios exclusivos e totalmente novos.</p>
                <div class="relative w-full max-w-4xl group">
                    <iframe src="https://www.youtube.com/embed/5KII7ydq2No" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" class="w-full aspect-video rounded-3xl shadow-2xl transform group-hover:scale-[1.02] transition-transform duration-500" allowfullscreen loading="lazy"></iframe>
                </div>
            </div>

            <div class="flex flex-col gap-12">
                <div class="text-center">
                    <h2 class="text-4xl lg:text-5xl font-black mb-4 bg-linear-to-r from-white to-gray-300 bg-clip-text text-transparent">Não perca nada!</h2>
                    <p class="text-xl text-gray-400 max-w-3xl mx-auto">O Summer Game Fest é um agregado de eventos, há outros eventos imperdíveis na mesma semana.</p>
                </div>
                <EventCalendar client:load />
            </div>
        </div>
    </div>
</BaseLayout>