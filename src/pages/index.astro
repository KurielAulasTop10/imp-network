---
import { differenceInDays } from "date-fns";
import HomePageContent from "@/components/HomePageContent";
import Sidebar from "@/components/Sidebar";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchTodayGames } from "@/lib/igdb";
import { createClient } from "@/prismicio";

const clientPrismic = createClient({ fetchOptions: { cache: "no-cache" } });
const allPosts = await clientPrismic.getAllByType("post", {
	orderings: {
		field: "my.post.data",
		direction: "desc",
	},
	fetchLinks: ["author.avatar", "author.banner", "author.descricao"],
});

const allAuthors = await clientPrismic.getAllByType("author");
const authorsMap = new Map(allAuthors.map((a) => [a.uid, a]));

const { gamesData, coversData } = await fetchTodayGames();

const serializedGamesData = gamesData
	? { data: gamesData.data.map((g) => ({ id: g.id, url: g.url, name: g.name })) }
	: undefined;
const serializedCoversData = coversData
	? coversData.map((c) => ({ id: c?.id, url: c?.url }))
	: undefined;

const sgfDate = new Date("2026-06-05T14:00:00-07:00");
const daysUntilSgf = differenceInDays(sgfDate, new Date());
const showSgfBanner = daysUntilSgf >= 0 && daysUntilSgf <= 30;
---

<BaseLayout title="Império Network">
	<div class="grid grid-cols-1 md:grid-cols-5 w-full items-start mt-5 md:mt-10 px-2 md:px-5 gap-10">
		<div class="w-full md:col-span-4">
			{
				showSgfBanner && (
					<a href="/summer-game-fest" class="block mb-8 group">
						<div class="bg-linear-to-r from-red-600/20 to-red-500/10 border border-red-500/30 rounded-2xl p-6 hover:from-red-600/30 hover:to-red-500/20 transition-all duration-300">
							<div class="flex items-center gap-4 flex-col sm:flex-row text-center sm:text-left">
								<div class="size-16 shrink-0 rounded-xl bg-red-600/20 flex items-center justify-center text-3xl">
									<svg class="size-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
										<path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
										<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
								</div>
								<div class="flex-1">
									<p class="text-sm font-bold text-red-400 uppercase tracking-wider">Evento em {daysUntilSgf} dias</p>
									<h3 class="text-xl font-bold text-white mt-1 group-hover:text-red-400 transition-colors">Summer Game Fest está chegando!</h3>
									<p class="text-gray-400 mt-1">O maior evento de anúncios de jogos está prestes a começar. Fique por dentro de tudo.</p>
								</div>
								<div class="bg-red-600 hover:bg-red-500 text-white px-6 py-3 rounded-xl font-bold transition-colors shrink-0 group-hover:scale-105 transform">
									Ver Programação
								</div>
							</div>
						</div>
					</a>
				)
			}
			<HomePageContent client:idle allPosts={allPosts} authorsMap={authorsMap} />
		</div>
		<Sidebar client:idle gamesData={serializedGamesData} coversData={serializedCoversData} />
	</div>
</BaseLayout>
