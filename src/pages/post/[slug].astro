---
import PostPageContent from "@/components/PostPageContent";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { createClient } from "@/prismicio";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const client = createClient({ fetchOptions: { cache: "no-cache" } });
const article = await client.getByUID("post", slug).catch(() => null);

if (!article) {
	return Astro.redirect("/404");
}

interface MyAuthorData {
	uid?: string;
}

const myAuthorData = article.data.author as unknown as MyAuthorData;

if (!myAuthorData?.uid) {
	return Astro.redirect("/404");
}

const author = await client
	.getByUID("author", myAuthorData.uid)
	.catch(() => null);

if (!author) {
	return Astro.redirect("/404");
}

if (!article?.data?.seo_description) {
	const editorContent = article.data.editor
		? JSON.stringify(article.data.editor)
		: "";
	const isFreeCategory = article.tags.includes("Grátis");

	await fetch(
		`${new URL(Astro.request.url).origin}/api/generate-ai`,
		{
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({
				title: article.data.titulo,
				article: editorContent,
				slug: slug,
				SEOOnly: isFreeCategory,
			}),
		},
	).catch(() => null);

}

const ads = await client.getAllByType("anuncio").catch(() => []);
const adsSorted = ads.sort(() => Math.random() - 0.5);
---

<BaseLayout title={article.data.titulo} description={article?.data?.seo_description} image={article.data.cover.url}>
	<PostPageContent
		client:idle
		article={article}
		author={author}
		adsSorted={adsSorted}
	/>
</BaseLayout>
